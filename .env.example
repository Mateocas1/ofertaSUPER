# Database
# Use Supabase pooler for runtime queries.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=3"

# Use direct Supabase connection for migrations and administrative tasks.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB"

# VTEX scraping
# Keep this server-side. Never expose it as NEXT_PUBLIC_*.
VTEX_SHA256_HASH="REPLACE_WITH_SERVER_SIDE_HASH"
VTEX_REQUEST_MIN_DELAY_MS=800
VTEX_REQUEST_MAX_DELAY_MS=2500
VTEX_USER_AGENTS="Mozilla/5.0 example|Mozilla/5.0 example 2"

# Public site metadata
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Clerk admin auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_REPLACE_ME"
CLERK_SECRET_KEY="sk_test_REPLACE_ME"
ADMIN_EMAILS="admin@example.com"

# Upstash Redis cache/rate-limit
UPSTASH_REDIS_REST_URL="https://example.invalid"
UPSTASH_REDIS_REST_TOKEN="REPLACE_ME"

# Optional scraper/ingestion controls
SCRAPER_ALERT_WEBHOOK_URL=""
SCRAPER_JOB_NAME="local"
SCRAPER_JOB_STATUS="manual"
INGESTION_V2="shadow"
DB_CONNECTION_LIMIT=3
DB_POOL_TIMEOUT=10
RECONCILE_TX_MAX_WAIT_MS=15000
RECONCILE_TX_TIMEOUT_MS=120000

# Optional local troubleshooting flag. Keep false for normal builds; do not use as a final PWA workaround without an explicit decision.
DISABLE_PWA=false
